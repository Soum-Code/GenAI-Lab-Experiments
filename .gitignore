# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   often version-specific. See https://github.com/pyenv/pyenv#environment-variables
#  .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or even
#   fail to install them.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed, but in some cases
#   might be ignored.
# poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally recommended to be committed, but in some cases
#   might be ignored.
# pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
